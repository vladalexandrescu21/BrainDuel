rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read any profile (for leaderboard, opponent info)
      allow read: if request.auth != null;

      // Only the owner can write their own profile
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && isValidNewProfile(request.resource.data);

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && isValidProfileUpdate(request.resource.data);

      allow delete: if false; // Never delete profiles
    }

    // ── Leaderboard (read-only computed view) ──────────────────────────────
    match /leaderboard/{entry} {
      allow read: if request.auth != null;
      allow write: if false; // Written only by Cloud Functions
    }

    // ── Questions (read-only for clients) ─────────────────────────────────
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false; // Only via admin/server
    }

    // ── Shop items ────────────────────────────────────────────────────────
    match /shop_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Functions ─────────────────────────────────────────────────────────
    function isValidNewProfile(data) {
      return data.keys().hasAll(['displayName', 'email', 'level', 'xp', 'coins',
                                  'avatarId', 'selectedAbilities', 'stats', 'createdAt'])
          && data.displayName is string
          && data.displayName.size() >= 1
          && data.displayName.size() <= 50
          && data.level == 1
          && data.xp == 0
          && data.coins == 100
          && data.stats.wins == 0
          && data.stats.losses == 0
          && data.stats.draws == 0
          && data.stats.totalGames == 0;
    }

    function isValidProfileUpdate(data) {
      // Prevent client from setting arbitrary XP/coins (server does this via Admin SDK)
      // Allow updating: displayName, avatarId, selectedAbilities
      let allowedFields = ['displayName', 'avatarId', 'selectedAbilities'];
      return request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(allowedFields);
    }
  }
}
